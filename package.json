{
  "name": "aboard",
  "version": "1.0.0",
  "description": "Lightweight coordination system for local coding-agent sessions",
  "type": "module",
  "license": "MIT",
  "bin": {
    "aboard-server": "./bin/aboard-server.js",
    "aboard-mcp": "./bin/aboard-mcp.js"
  },
  "files": [
    "bin",
    "src",
    "skills",
    ".claude-plugin"
  ],
  "scripts": {
    "start:server": "node ./bin/aboard-server.js",
    "start:mcp": "node ./bin/aboard-mcp.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.31",
    "tsx": "^4.23.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
